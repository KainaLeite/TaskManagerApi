# Chave secreta usada para assinar os tokens JWT.
# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_aqui

# Algoritmo de assinatura do JWT (não altere sem motivo)
ALGORITHM=HS256

# Tempo de expiração do token de acesso em minutos
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Turso (libSQL) — banco de dados remoto
# URL no formato: libsql://[nome-db]-[org].aws-us-east-2.turso.io
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu_token_aqui
